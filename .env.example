# Local non-secret defaults.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/realestate
SPRING_DATASOURCE_USERNAME=realestate
SPRING_DATASOURCE_PASSWORD=change-me-locally
REALESTATE_PUBLIC_BASE_URL=https://realestate.localhost
REALESTATE_JWT_SECRET=replace-with-at-least-32-random-bytes
REALESTATE_IDENTITY_MODE=local
REALESTATE_KEYCLOAK_ISSUER_URI=http://localhost:8180/realms/realestate
REALESTATE_KEYCLOAK_CLIENT_ID=realestate-os
REALESTATE_MAIL_ENABLED=false
REALESTATE_MAIL_FROM=no-reply@realestate.localhost
REALESTATE_MAIL_FROM_NAME=Real Estate OS
REALESTATE_DOCUMENT_STORAGE_ROOT=./output/document-storage
REALESTATE_DOCUMENT_STORAGE_MAX_FILE_SIZE_BYTES=26214400

# Stage SMTP is configured on the server from a private secret file.
# Never commit real SMTP usernames or passwords.
